#! /bin/sh
# Automate the running of the configure script if you're
# too lazy to type 'perl configure.pl'
#
# For the CD to work at the end of the script you need to "source"
# the script in the parent process by typeing:
#
#		. configure
#
# Without sourcing the script it will run the same as typing
# 'perl configure.pl
#
perl configure.pl
result=$?
echo "exit code: ${result}"
if [ "${result}" -eq "0" ] ; then
    echo "Changing directory..."
    cd build
fi

